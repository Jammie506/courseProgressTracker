{
  "name": "sorted",
  "version": "1.0.1",
  "description": "Track learner progress through course modules",
  "author": "Jamie McCarthy",
  "main": "assets/scripts/main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build-win": "electron-builder --win --publish never",
    "build-win-portable": "electron-builder --win portable --publish never"
  },
  "dependencies": {
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.learnerprogresstracker.app",
    "productName": "Sorted",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "assets/scripts/main.js",
      "assets/scripts/preload.js",
      "index.html",
      "assets/scripts/renderer.js",
      "assets/style/styles.css",
      "assets/data/sample-courses.json",
      "data/**/*"
    ],
    "win": {
      "icon": "assets/images/sortedLogo.ico",
      "executableName": "Sorted",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sorted",
      "artifactName": "Sorted-Setup.${ext}"
    },
    "portable": {
      "artifactName": "Sorted.${ext}"
    }
  }
}
